<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_page_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_menu_icon"
                android:contentDescription="Ikon home visit"
                android:padding="10dp"
                android:src="@drawable/ic_menu_home_visit" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Home Visit"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Dokumentasi kunjungan rumah siswa"
                    android:textColor="#EAF5FF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_bg"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText android:id="@+id/etNama" style="@style/FormInputStyle" android:hint="Nama siswa" />
            <EditText android:id="@+id/etKelas" style="@style/FormInputStyle" android:layout_marginTop="10dp" android:hint="Kelas" />
            <EditText
                android:id="@+id/etHasil"
                style="@style/FormInputStyle"
                android:layout_height="120dp"
                android:layout_marginTop="10dp"
                android:gravity="top"
                android:hint="Hasil kunjungan" />

            <Button
                android:id="@+id/btnFoto"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_secondary_button"
                android:backgroundTint="@null"
                android:text="Ambil Foto"
                android:textAllCaps="false"
                android:textColor="@color/primary_dark"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgFoto"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_soft_panel"
                android:contentDescription="Foto home visit"
                android:scaleType="centerCrop" />

            <Button
                android:id="@+id/btnLokasi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_secondary_button"
                android:backgroundTint="@null"
                android:text="Ambil Lokasi GPS"
                android:textAllCaps="false"
                android:textColor="@color/primary_dark"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLokasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_soft_panel"
                android:padding="12dp"
                android:text="Lokasi belum diambil"
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_primary_button"
                android:backgroundTint="@null"
                android:text="Simpan Home Visit"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
