<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_page_header"
            android:elevation="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <ImageView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:contentDescription="Ikon surat pemanggilan"
                android:src="@drawable/ic_menu_surat" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Surat Pemanggilan"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Form panggilan orang tua siswa"
                    android:textColor="#EAF5FF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/PageSectionTitleStyle"
            android:layout_marginTop="22dp"
            android:text="Data Surat" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <EditText
                android:id="@+id/etNamaSurat"
                style="@style/FormInputStyle"
                android:hint="Nama Siswa" />

            <EditText
                android:id="@+id/etKelasSurat"
                style="@style/FormInputStyle"
                android:layout_marginTop="12dp"
                android:hint="Kelas" />

            <EditText
                android:id="@+id/etAlasanSurat"
                style="@style/FormInputStyle"
                android:layout_marginTop="12dp"
                android:hint="Alasan Pemanggilan" />

            <EditText
                android:id="@+id/etTanggalSurat"
                style="@style/FormInputStyle"
                android:layout_marginTop="12dp"
                android:hint="Tanggal Pemanggilan" />

            <Button
                android:id="@+id/btnBuatSurat"
                style="@style/PrimaryButtonStyle"
                android:layout_marginTop="16dp"
                android:text="Buat Surat" />

            <TextView
                android:id="@+id/tvHasilSurat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_list_surface"
                android:padding="14dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnExportPdf"
                style="@style/SecondaryButtonStyle"
                android:layout_marginTop="12dp"
                android:text="Export PDF" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
