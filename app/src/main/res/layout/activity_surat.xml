<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_page_header"
            android:elevation="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <ImageView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:contentDescription="Ikon surat"
                android:src="@drawable/ic_menu_surat" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Layanan Surat"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Pilih jenis surat untuk dibuat"
                    android:textColor="#EAF5FF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/PageSectionTitleStyle"
            android:layout_marginTop="22dp"
            android:text="Pilih Jenis Surat" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:columnCount="2">

            <LinearLayout
                android:id="@+id/menuSuratPemanggilan"
                style="@style/MenuCardStyle">
                <ImageView style="@style/MenuIconStyle" android:contentDescription="Ikon surat pemanggilan" android:src="@drawable/ic_menu_surat" />
                <TextView style="@style/MenuTitleStyle" android:text="Surat Pemanggilan Orang Tua" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuSuratPernyataan"
                style="@style/MenuCardStyle">
                <ImageView style="@style/MenuIconStyle" android:contentDescription="Ikon surat pernyataan" android:src="@drawable/ic_assignment" />
                <TextView style="@style/MenuTitleStyle" android:text="Surat Pernyataan" />
            </LinearLayout>
        </GridLayout>
    </LinearLayout>
</ScrollView>
